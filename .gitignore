# ============================================================
# Travellers Rest Planner — gitignore
# ============================================================

# ── Extracted game assets ───────────────────────────────────
# Generated by scripts/dump_*.py from a local Travellers Rest install.
# These contain copyrighted game assets (sprites, localization strings,
# scene tilemaps, ScriptableObject contents) and MUST NOT be committed.
# Each user runs the extraction scripts against their own game install.
dumps/
data/icons/
data/maps/
data/i18n.json
data/maps.json
data/hotspots.json
data/items.json
data/recipes.csv
data/crops.csv
data/foods.csv

# Decompiled C# source — pulled from the game DLL with ilspycmd.
# Useful for development reference but copyrighted by Louqou.
dumps/*.cs
dumps/sirenix/

# ── Local config ────────────────────────────────────────────
.env
.env.local
.claude/
.vscode/
.idea/
CLAUDE.md
*.swp
*.swo

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg

# Virtual envs
venv/
.venv/
env/
ENV/

# ── Node / Vite (optional React UI) ─────────────────────────
planner/web/node_modules/
planner/web/dist/
planner/web/.vite/
*.log
npm-debug.log*

# ── OS noise ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
mod/
scripts/deobfuscate.py
scripts/deobfuscate_all.py
scripts/fix_csproj.py
scripts/trainer.py
scripts/savepatch.py
resolve
